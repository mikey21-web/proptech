// ClickProps CRM — Prisma Schema
// 1:1 replacement for Blindersoe real estate CRM (Sri Sai Builders)
// PostgreSQL 15, multi-tenant, soft deletes, full audit trail

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserStatus {
  active
  inactive
  suspended
}

enum LeadStatusEnum {
  new
  contacted
  qualified
  negotiation
  site_visit
  proposal_sent
  won
  lost
  junk
}

enum LeadPriority {
  low
  medium
  high
  urgent
}

enum CommunicationType {
  call
  email
  sms
  whatsapp
  meeting
  site_visit
  other
}

enum CommunicationDirection {
  inbound
  outbound
}

enum ActivityType {
  call
  email
  meeting
  site_visit
  follow_up
  note
  status_change
  document_upload
  other
}

enum TaskStatus {
  pending
  in_progress
  completed
  cancelled
  overdue
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum ProjectType {
  residential
  commercial
  mixed
  villa
  plot
  apartment
}

enum ProjectStatusEnum {
  upcoming
  under_construction
  ready_to_move
  completed
  on_hold
  cancelled
}

enum PlotStatus {
  available
  reserved
  booked
  sold
  mortgaged
  blocked
}

enum FlatStatus {
  available
  reserved
  booked
  sold
  blocked
}

enum BookingStatusEnum {
  pending
  confirmed
  agreement_signed
  registration_done
  possession_given
  cancelled
  refunded
}

enum PaymentModeEnum {
  cash
  cheque
  bank_transfer
  upi
  credit_card
  debit_card
  demand_draft
  emi
  loan
  other
}

enum PaymentStatus {
  pending
  received
  verified
  bounced
  refunded
  cancelled
}

enum InstallmentStatus {
  upcoming
  due
  overdue
  paid
  partially_paid
  waived
  cancelled
}

enum TransactionType {
  payment
  refund
  commission
  adjustment
  penalty
  discount
}

enum RefundStatus {
  requested
  approved
  processing
  completed
  rejected
}

enum CommissionStatus {
  pending
  approved
  paid
  cancelled
  clawed_back
}

enum CommissionType {
  percentage
  flat
  tiered
}

enum LoanStatusEnum {
  applied
  documents_submitted
  under_review
  sanctioned
  disbursed
  rejected
  closed
}

enum LoanInstallmentStatus {
  upcoming
  due
  overdue
  paid
  defaulted
}

enum DocumentType {
  aadhaar
  pan
  passport
  driving_license
  voter_id
  bank_statement
  salary_slip
  itr
  property_document
  agreement
  receipt
  photo
  other
}

enum WebhookEvent {
  lead_created
  lead_updated
  booking_created
  booking_updated
  payment_received
  payment_overdue
  commission_approved
  customer_created
  project_updated
}

enum AuditAction {
  create
  update
  delete
  login
  logout
  export
  import
  bulk_update
}

// ============================================================================
// GROUP 1: NextAuth.js Models (preserved for authentication)
// ============================================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// GROUP 2: Organizations & Access (6 tables)
// ============================================================================

model Organization {
  id          String   @id @default(cuid())
  name        String
  domain      String?  @unique
  logo        String?
  address     String?
  phone       String?
  email       String?
  gstNumber   String?
  reraNumber  String?
  website     String?
  settings    Json?    // org-level settings (currency, timezone, etc.)

  users       User[]
  roles       Role[]
  projects    Project[]
  leads       Lead[]
  bookings    Booking[]
  customers   Customer[]
  agents      Agent[]
  loans       Loan[]
  commissionStructures CommissionStructure[]
  configurations       Configuration[]
  auditLogs   AuditLog[]
  webhooks    Webhook[]
  leadSources LeadSource[]

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@index([name])
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String
  phone         String?
  password      String?
  emailVerified DateTime?
  image         String?
  status        UserStatus @default(active)

  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  // NextAuth relations
  accounts      Account[]
  sessions      Session[]

  // CRM relations
  userRoles         UserRole[]
  assignedLeads     Lead[]          @relation("AssignedTo")
  createdLeads      Lead[]          @relation("CreatedBy")
  communications    Communication[]
  activities        Activity[]
  tasks             Task[]          @relation("TaskAssignee")
  createdTasks      Task[]          @relation("TaskCreator")
  notes             Note[]
  bookings          Booking[]
  agent             Agent?
  auditLogs         AuditLog[]

  createdAt     DateTime  @default(now()) @db.Timestamp()
  updatedAt     DateTime  @updatedAt @db.Timestamp()
  deletedAt     DateTime? @db.Timestamp()

  @@index([email])
  @@index([orgId])
  @@index([status])
}

model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean  @default(false) // system roles cannot be deleted

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@unique([orgId, name])
  @@index([orgId])
}

model Permission {
  id          String   @id @default(cuid())
  resource    String   // e.g. "lead", "booking", "project"
  action      String   // e.g. "create", "read", "update", "delete"
  description String?

  rolePermissions RolePermission[]

  createdAt   DateTime @default(now()) @db.Timestamp()
  updatedAt   DateTime @updatedAt @db.Timestamp()

  @@unique([resource, action])
  @@index([resource])
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp()

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp()

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// ============================================================================
// GROUP 3: Leads & CRM (7 tables)
// ============================================================================

model LeadSource {
  id    String @id @default(cuid())
  name  String // e.g. "99acres", "MagicBricks", "Walk-in", "Referral"
  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  leads Lead[]

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()

  @@unique([orgId, name])
  @@index([orgId])
}

model LeadStatus {
  id          String @id @default(cuid())
  name        String
  color       String? // hex color for UI
  sortOrder   Int     @default(0)
  isFinal     Boolean @default(false) // won/lost/junk are final

  leads Lead[]

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()

  @@unique([name])
}

model Lead {
  id          String          @id @default(cuid())
  name        String
  email       String?
  phone       String
  altPhone    String?
  status      LeadStatusEnum  @default(new)
  priority    LeadPriority    @default(medium)
  budget      Decimal?        @db.Decimal(14, 2)
  notes       String?         @db.Text
  source      String?         // free-text source (legacy compat)

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  assignedToId String?
  assignedTo   User?    @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById  String?
  createdBy    User?    @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  leadSourceId String?
  leadSource   LeadSource? @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)

  leadStatusId String?
  leadStatus   LeadStatus? @relation(fields: [leadStatusId], references: [id], onDelete: SetNull)

  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  communications Communication[]
  activities     Activity[]
  tasks          Task[]
  leadNotes      Note[]

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()

  @@index([orgId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
  @@index([phone])
  @@index([email])
  @@index([projectId])
  @@index([createdAt])
  @@index([orgId, status])
}

model Communication {
  id        String               @id @default(cuid())
  type      CommunicationType
  direction CommunicationDirection
  subject   String?
  body      String?              @db.Text
  duration  Int?                 // duration in seconds (for calls)
  outcome   String?

  leadId    String
  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId    String?
  user      User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  title       String
  description String?      @db.Text
  metadata    Json?        // flexible data for different activity types

  leadId      String?
  lead        Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId      String?
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()

  @@index([leadId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(pending)
  priority    TaskPriority @default(medium)
  dueDate     DateTime?    @db.Timestamp()
  completedAt DateTime?    @db.Timestamp()

  leadId      String?
  lead        Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  assigneeId  String?
  assignee    User? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId   String?
  creator     User? @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@index([leadId])
  @@index([assigneeId])
  @@index([status])
  @@index([dueDate])
  @@index([priority])
}

model Note {
  id      String @id @default(cuid())
  content String @db.Text
  isPinned Boolean @default(false)

  leadId  String?
  lead    Lead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  userId  String?
  user    User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()

  @@index([leadId])
  @@index([userId])
}

// ============================================================================
// GROUP 4: Projects & Inventory (6 tables)
// ============================================================================

model Project {
  id            String            @id @default(cuid())
  name          String
  slug          String
  description   String?           @db.Text
  type          ProjectType       @default(residential)
  status        ProjectStatusEnum @default(upcoming)
  address       String?
  city          String?
  state         String?
  pincode       String?
  latitude      Decimal?          @db.Decimal(10, 8)
  longitude     Decimal?          @db.Decimal(11, 8)
  totalArea     Decimal?          @db.Decimal(12, 2) // in sq ft
  totalUnits    Int?
  launchDate    DateTime?         @db.Timestamp()
  completionDate DateTime?        @db.Timestamp()
  reraNumber    String?
  brochureUrl   String?
  sitePlanUrl   String?           // Site plan image URL for 2D layout overlay
  sitePlanWidth Int?              // Original image width in pixels
  sitePlanHeight Int?             // Original image height in pixels

  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  plots         Plot[]
  flats         Flat[]
  amenities     Amenity[]
  images        ProjectImage[]
  leads         Lead[]
  bookings      Booking[]
  commissionRules CommissionRule[]

  createdAt     DateTime  @default(now()) @db.Timestamp()
  updatedAt     DateTime  @updatedAt @db.Timestamp()
  deletedAt     DateTime? @db.Timestamp()

  @@unique([orgId, slug])
  @@index([orgId])
  @@index([status])
  @@index([city])
  @@index([type])
}

model Plot {
  id          String     @id @default(cuid())
  plotNumber  String
  area        Decimal    @db.Decimal(10, 2) // in sq ft
  dimensions  String?    // e.g. "30x40"
  facing      String?    // North, South, East, West, etc.
  price       Decimal    @db.Decimal(14, 2)
  pricePerSqft Decimal?  @db.Decimal(10, 2)
  status      PlotStatus @default(available)
  floorPlan   String?    // URL
  coordinates  Json?      // Polygon vertices: [[x1,y1],[x2,y2],...] for site plan overlay
  remarks      String?
  blockedUntil DateTime? @db.Timestamp() // auto-expiry for plot blocks
  blockReason  String?

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  bookings    Booking[] @relation("PlotBooking")

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@unique([projectId, plotNumber])
  @@index([projectId])
  @@index([status])
  @@index([price])
}

model Flat {
  id          String     @id @default(cuid())
  flatNumber  String
  floor       Int
  bedrooms    Int
  bathrooms   Int
  area        Decimal    @db.Decimal(10, 2) // carpet area in sq ft
  superArea   Decimal?   @db.Decimal(10, 2) // super built-up area
  facing      String?
  price       Decimal    @db.Decimal(14, 2)
  pricePerSqft Decimal?  @db.Decimal(10, 2)
  status      FlatStatus @default(available)
  floorPlan   String?
  coordinates  Json?      // Polygon vertices for floor plan overlay
  remarks      String?
  blockedUntil DateTime? @db.Timestamp() // auto-expiry for flat blocks
  blockReason  String?

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  bookings    Booking[] @relation("FlatBooking")

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@unique([projectId, flatNumber])
  @@index([projectId])
  @@index([status])
  @@index([price])
  @@index([bedrooms])
}

model Amenity {
  id          String  @id @default(cuid())
  name        String
  description String?
  icon        String? // icon identifier for UI

  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @db.Timestamp()
  updatedAt   DateTime @updatedAt @db.Timestamp()

  @@unique([projectId, name])
  @@index([projectId])
}

model ProjectImage {
  id        String  @id @default(cuid())
  url       String
  caption   String?
  sortOrder Int     @default(0)
  isPrimary Boolean @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp()
  updatedAt DateTime @updatedAt @db.Timestamp()

  @@index([projectId])
}

model ProjectStatus {
  id          String @id @default(cuid())
  name        String @unique
  color       String?
  sortOrder   Int    @default(0)
  description String?

  createdAt DateTime @default(now()) @db.Timestamp()
  updatedAt DateTime @updatedAt @db.Timestamp()
}

// ============================================================================
// GROUP 5: Bookings & Transactions (7 tables)
// ============================================================================

model Booking {
  id              String            @id @default(cuid())
  bookingNumber   String            @unique
  status          BookingStatusEnum @default(pending)
  bookingDate     DateTime          @db.Timestamp()
  agreementDate   DateTime?         @db.Timestamp()
  registrationDate DateTime?        @db.Timestamp()
  possessionDate  DateTime?         @db.Timestamp()
  totalAmount     Decimal           @db.Decimal(14, 2)
  discountAmount  Decimal           @default(0) @db.Decimal(14, 2)
  netAmount       Decimal           @db.Decimal(14, 2)
  paidAmount      Decimal           @default(0) @db.Decimal(14, 2)
  balanceAmount   Decimal           @default(0) @db.Decimal(14, 2)
  gstAmount       Decimal           @default(0) @db.Decimal(14, 2)
  stampDuty       Decimal           @default(0) @db.Decimal(14, 2)
  registrationFee Decimal           @default(0) @db.Decimal(14, 2)
  remarks         String?           @db.Text

  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  projectId       String
  project         Project @relation(fields: [projectId], references: [id], onDelete: Restrict)

  plotId          String?
  plot            Plot? @relation("PlotBooking", fields: [plotId], references: [id], onDelete: SetNull)

  flatId          String?
  flat            Flat? @relation("FlatBooking", fields: [flatId], references: [id], onDelete: SetNull)

  agentId         String?
  agent           Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  createdById     String?
  createdBy       User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  payments        Payment[]
  installments    Installment[]
  transactions    Transaction[]
  refunds         Refund[]
  commissions     Commission[]
  loans           Loan[]

  createdAt       DateTime  @default(now()) @db.Timestamp()
  updatedAt       DateTime  @updatedAt @db.Timestamp()
  deletedAt       DateTime? @db.Timestamp()

  @@index([orgId])
  @@index([customerId])
  @@index([projectId])
  @@index([agentId])
  @@index([status])
  @@index([bookingDate])
  @@index([bookingNumber])
  @@index([orgId, status])
}

model Payment {
  id            String         @id @default(cuid())
  receiptNumber String?        @unique
  amount        Decimal        @db.Decimal(14, 2)
  mode          PaymentModeEnum
  status        PaymentStatus  @default(pending)
  paymentDate   DateTime       @db.Timestamp()
  referenceNo   String?        // cheque number, transaction ID, etc.
  bankName      String?
  remarks       String?

  bookingId     String
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  installmentId String?
  installment   Installment? @relation(fields: [installmentId], references: [id], onDelete: SetNull)

  transactions  Transaction[]

  createdAt     DateTime  @default(now()) @db.Timestamp()
  updatedAt     DateTime  @updatedAt @db.Timestamp()
  deletedAt     DateTime? @db.Timestamp()

  @@index([bookingId])
  @@index([status])
  @@index([paymentDate])
  @@index([mode])
  @@index([bookingId, status])
}

model Installment {
  id            String            @id @default(cuid())
  installmentNo Int
  amount        Decimal           @db.Decimal(14, 2)
  dueDate       DateTime          @db.Timestamp()
  paidAmount    Decimal           @default(0) @db.Decimal(14, 2)
  status        InstallmentStatus @default(upcoming)
  paidDate      DateTime?         @db.Timestamp()
  remarks       String?

  bookingId     String
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  payments      Payment[]

  deletedAt     DateTime? @db.Timestamp()
  createdAt     DateTime  @default(now()) @db.Timestamp()
  updatedAt     DateTime  @updatedAt @db.Timestamp()

  @@unique([bookingId, installmentNo])
  @@index([bookingId])
  @@index([dueDate])
  @@index([status])
  @@index([bookingId, status])
}

model Transaction {
  id            String          @id @default(cuid())
  type          TransactionType
  amount        Decimal         @db.Decimal(14, 2)
  description   String?
  referenceNo   String?

  bookingId     String
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  paymentId     String?
  payment       Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  deletedAt     DateTime? @db.Timestamp()
  createdAt     DateTime @default(now()) @db.Timestamp()
  updatedAt     DateTime @updatedAt @db.Timestamp()

  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
  @@index([paymentId])
}

model Refund {
  id            String       @id @default(cuid())
  amount        Decimal      @db.Decimal(14, 2)
  reason        String?      @db.Text
  status        RefundStatus @default(requested)
  approvedAt    DateTime?    @db.Timestamp()
  processedAt   DateTime?    @db.Timestamp()
  referenceNo   String?

  bookingId     String
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  deletedAt     DateTime? @db.Timestamp()
  createdAt     DateTime  @default(now()) @db.Timestamp()
  updatedAt     DateTime  @updatedAt @db.Timestamp()

  @@index([bookingId])
  @@index([status])
}

model BookingStatus {
  id          String  @id @default(cuid())
  name        String  @unique
  color       String?
  sortOrder   Int     @default(0)
  description String?

  createdAt DateTime @default(now()) @db.Timestamp()
  updatedAt DateTime @updatedAt @db.Timestamp()
}

model PaymentMode {
  id          String  @id @default(cuid())
  name        String  @unique
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now()) @db.Timestamp()
  updatedAt DateTime @updatedAt @db.Timestamp()
}

// ============================================================================
// GROUP 6: Customers (3 tables)
// ============================================================================

model Customer {
  id          String  @id @default(cuid())
  name        String
  email       String?
  phone       String
  altPhone    String?
  address     String? @db.Text
  city        String?
  state       String?
  pincode     String?
  dateOfBirth DateTime? @db.Date
  panNumber   String?
  aadhaarNumber String?
  gstNumber   String?
  occupation  String?
  companyName String?
  notes       String? @db.Text

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  contacts    CustomerContact[]
  documents   CustomerDocument[]
  bookings    Booking[]
  leads       Lead[]
  loans       Loan[]

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@index([orgId])
  @@index([phone])
  @@index([email])
  @@index([name])
  @@index([orgId, phone])
}

model CustomerContact {
  id          String  @id @default(cuid())
  name        String
  relation    String  // e.g. "spouse", "father", "nominee"
  phone       String?
  email       String?
  isPrimary   Boolean @default(false)

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @db.Timestamp()
  updatedAt   DateTime @updatedAt @db.Timestamp()

  @@index([customerId])
}

model CustomerDocument {
  id           String       @id @default(cuid())
  type         DocumentType
  documentNo   String?
  fileUrl      String
  fileName     String?
  fileSize     Int?         // in bytes
  isVerified   Boolean      @default(false)
  verifiedAt   DateTime?    @db.Timestamp()
  expiryDate   DateTime?    @db.Date

  customerId   String
  customer     Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt    DateTime  @default(now()) @db.Timestamp()
  updatedAt    DateTime  @updatedAt @db.Timestamp()

  @@index([customerId])
  @@index([type])
}

// ============================================================================
// GROUP 7: Agents & Commissions (5 tables)
// ============================================================================

model Agent {
  id            String  @id @default(cuid())
  agentCode     String  @unique
  reraNumber    String?
  panNumber     String?
  bankAccount   String?
  ifscCode      String?
  bankName      String?
  isActive      Boolean @default(true)

  userId        String  @unique
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId         String
  org           Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  teamId        String?
  team          AgentTeam? @relation("TeamMembers", fields: [teamId], references: [id], onDelete: SetNull)

  ledTeams      AgentTeam[] @relation("TeamLeader")
  bookings      Booking[]
  commissions   Commission[]

  createdAt     DateTime  @default(now()) @db.Timestamp()
  updatedAt     DateTime  @updatedAt @db.Timestamp()
  deletedAt     DateTime? @db.Timestamp()

  @@index([orgId])
  @@index([agentCode])
  @@index([isActive])
}

model AgentTeam {
  id          String  @id @default(cuid())
  name        String
  description String?

  leaderId    String?
  leader      Agent? @relation("TeamLeader", fields: [leaderId], references: [id], onDelete: SetNull)

  members     Agent[] @relation("TeamMembers")

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@index([leaderId])
}

model CommissionStructure {
  id          String         @id @default(cuid())
  name        String
  type        CommissionType @default(percentage)
  isDefault   Boolean        @default(false)
  isActive    Boolean        @default(true)

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  rules       CommissionRule[]

  createdAt   DateTime  @default(now()) @db.Timestamp()
  updatedAt   DateTime  @updatedAt @db.Timestamp()
  deletedAt   DateTime? @db.Timestamp()

  @@index([orgId])
  @@index([isActive])
}

model CommissionRule {
  id              String  @id @default(cuid())
  minAmount       Decimal @default(0) @db.Decimal(14, 2)
  maxAmount       Decimal? @db.Decimal(14, 2)
  percentage      Decimal? @db.Decimal(5, 2)
  flatAmount      Decimal? @db.Decimal(14, 2)
  description     String?

  structureId     String
  structure       CommissionStructure @relation(fields: [structureId], references: [id], onDelete: Cascade)

  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt       DateTime @default(now()) @db.Timestamp()
  updatedAt       DateTime @updatedAt @db.Timestamp()

  @@index([structureId])
  @@index([projectId])
}

model Commission {
  id            String           @id @default(cuid())
  amount        Decimal          @db.Decimal(14, 2)
  percentage    Decimal?         @db.Decimal(5, 2)
  status        CommissionStatus @default(pending)
  approvedAt    DateTime?        @db.Timestamp()
  paidAt        DateTime?        @db.Timestamp()
  remarks       String?

  agentId       String?
  agent         Agent? @relation(fields: [agentId], references: [id], onDelete: SetNull)

  bookingId     String
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  deletedAt     DateTime? @db.Timestamp()
  createdAt     DateTime  @default(now()) @db.Timestamp()
  updatedAt     DateTime  @updatedAt @db.Timestamp()

  @@index([agentId])
  @@index([bookingId])
  @@index([status])
}

// ============================================================================
// GROUP 8: Loans (4 tables)
// ============================================================================

model Loan {
  id              String         @id @default(cuid())
  loanNumber      String         @unique
  bankName        String
  branchName      String?
  sanctionedAmount Decimal       @db.Decimal(14, 2)
  disbursedAmount Decimal        @default(0) @db.Decimal(14, 2)
  interestRate    Decimal        @db.Decimal(5, 2)
  tenureMonths    Int
  emiAmount       Decimal?       @db.Decimal(14, 2)
  status          LoanStatusEnum @default(applied)
  sanctionDate    DateTime?      @db.Timestamp()
  disbursementDate DateTime?     @db.Timestamp()
  remarks         String?

  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  bookingId       String
  booking         Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  installments    LoanInstallment[]
  documents       LoanDocument[]

  createdAt       DateTime  @default(now()) @db.Timestamp()
  updatedAt       DateTime  @updatedAt @db.Timestamp()
  deletedAt       DateTime? @db.Timestamp()

  @@index([orgId])
  @@index([customerId])
  @@index([bookingId])
  @@index([status])
  @@index([loanNumber])
}

model LoanInstallment {
  id            String                @id @default(cuid())
  installmentNo Int
  amount        Decimal               @db.Decimal(14, 2)
  principal     Decimal               @db.Decimal(14, 2)
  interest      Decimal               @db.Decimal(14, 2)
  dueDate       DateTime              @db.Timestamp()
  paidDate      DateTime?             @db.Timestamp()
  status        LoanInstallmentStatus @default(upcoming)

  loanId        String
  loan          Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now()) @db.Timestamp()
  updatedAt     DateTime @updatedAt @db.Timestamp()

  @@unique([loanId, installmentNo])
  @@index([loanId])
  @@index([dueDate])
  @@index([status])
}

model LoanDocument {
  id          String       @id @default(cuid())
  type        DocumentType
  documentNo  String?
  fileUrl     String
  fileName    String?
  fileSize    Int?
  isVerified  Boolean      @default(false)

  loanId      String
  loan        Loan @relation(fields: [loanId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @db.Timestamp()
  updatedAt   DateTime @updatedAt @db.Timestamp()

  @@index([loanId])
  @@index([type])
}

model LoanStatus {
  id          String  @id @default(cuid())
  name        String  @unique
  color       String?
  sortOrder   Int     @default(0)
  description String?

  createdAt DateTime @default(now()) @db.Timestamp()
  updatedAt DateTime @updatedAt @db.Timestamp()
}

// ============================================================================
// GROUP 9: Settings & Config (3 tables)
// ============================================================================

model Configuration {
  id    String @id @default(cuid())
  key   String
  value String @db.Text
  type  String @default("string") // string, number, boolean, json

  orgId String
  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamp()
  updatedAt DateTime @updatedAt @db.Timestamp()

  @@unique([orgId, key])
  @@index([orgId])
  @@index([key])
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  entity      String      // table name, e.g. "Lead", "Booking"
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?

  userId      String?
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  orgId       String
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now()) @db.Timestamp()

  @@index([orgId])
  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([orgId, entity])
}

model Webhook {
  id       String       @id @default(cuid())
  url      String
  event    WebhookEvent
  secret   String?
  isActive Boolean      @default(true)
  headers  Json?

  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now()) @db.Timestamp()
  updatedAt DateTime  @updatedAt @db.Timestamp()
  deletedAt DateTime? @db.Timestamp()

  @@index([orgId])
  @@index([event])
  @@index([isActive])
}
