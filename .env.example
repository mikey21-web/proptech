# ============================================
# ClickProps CRM - Environment Variables
# Copy this file to .env.local and fill in actual values
# ============================================

# PostgreSQL
DATABASE_URL="postgresql://clickprops:your_password@localhost:5432/clickprops?schema=public"
POSTGRES_USER=clickprops
POSTGRES_PASSWORD=your_secure_password

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth.js
NEXTAUTH_SECRET="your-secret-key-min-32-chars-here"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_TRUST_HOST=true

# Optional: Google OAuth (for future integration)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Application
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# Payment Gateway — RAZORPAY
# Get keys from: https://dashboard.razorpay.com/app/keys
# LIVE mode: Use production keys from Razorpay dashboard
# TEST mode: Use test keys (prefixed with "rzp_test_")
# ============================================
RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Set to "live" for production, "test" for sandbox
RAZORPAY_MODE="test"
# Webhook secret for verifying Razorpay webhook signatures
RAZORPAY_WEBHOOK_SECRET=""

# ============================================
# Payment Gateway — STRIPE (fallback)
# Get keys from: https://dashboard.stripe.com/apikeys
# ============================================
STRIPE_SECRET_KEY="sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
STRIPE_WEBHOOK_SECRET="whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ============================================
# Hetzner VPS (for deployment)
# ============================================
HETZNER_IP=your.vps.ip.address
HETZNER_USER=root

# Docker Registry
DOCKER_REGISTRY=ghcr.io/your-org
IMAGE_TAG=latest

# ============================================
# Notifications — SENDGRID (optional)
# ============================================
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@clickprops.in"
SENDGRID_FROM_NAME="ClickProps CRM"

# ============================================
# Notifications — TWILIO (optional)
# ============================================
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ============================================
# WhatsApp — EVOLUTION API (optional)
# ============================================
EVOLUTION_API_URL="https://your-evolution-api.com"
EVOLUTION_API_KEY=""

# Slack Notifications (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
