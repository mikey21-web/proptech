{
  "name": "clickprops-crm",
  "version": "1.0.0",
  "description": "ClickProps Real Estate CRM for Sri Sai Builders",
  "scripts": {
    "dev": "next dev --turbo -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:schema": "jest --testPathPattern=schema.test",
    "test:auth": "jest --testPathPattern=auth.test",
    "test:api": "jest --testPathPattern=api.test",
    "test:rbac": "jest --testPathPattern=rbac.test",
    "test:perf": "jest --testPathPattern=performance.test",
    "test:seed": "jest --testPathPattern=seed.test --testTimeout=30000",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "prisma:seed": "node --require ts-node/register prisma/seed.ts",
    "workers:start": "node scripts/start-workers.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "autoprefixer": "^10.4.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.10.0",
    "konva": "^9.3.22",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "postcss": "^8.4.0",
    "prisma": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.2",
    "react-konva": "^18.2.14",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "node --require ts-node/register prisma/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.42.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
